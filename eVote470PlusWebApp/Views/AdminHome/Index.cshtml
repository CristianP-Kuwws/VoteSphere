@{
    ViewData["Title"] = "Home";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0 fw-semibold">Administration Panel</h4>
        <small class="text-muted">Electoral summary by year</small>
    </div>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <form asp-controller="Election" asp-action="GetSummaryByYear" method="post">
            @Html.AntiForgeryToken()
            <div class="row g-2 align-items-end">
                <div class="col-auto">
                    <label class="form-label fw-medium mb-1">Election Year</label>
                    <select name="year" class="form-select">
                        @if (ViewBag.ElectionYears != null && ((List<int>)ViewBag.ElectionYears).Any())
                        {
                            foreach (var year in (List<int>)ViewBag.ElectionYears)
                            {
                                if (year == (int)ViewBag.SelectedYear)
                                {
                                    <option value="@year" selected>@year</option>
                                }
                                else
                                {
                                    <option value="@year">@year</option>
                                }
                            }
                        }
                        else
                        {
                            <option disabled selected>No registered elections</option>
                        }
                    </select>
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-dark">Get Electoral Summary</button>
                </div>
            </div>
        </form>
    </div>
</div>

<div id="summaryResults"></div>