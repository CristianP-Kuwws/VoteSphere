@model SavePoliticalPartyViewModel
@{
    bool isEdit = ViewBag.IsEdit == true;
    ViewData["Title"] = isEdit ? "Edit Political Party" : "New Political Party";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="mb-4">
    <h4 class="fw-semibold mb-0">@ViewData["Title"]</h4>
    <small class="text-muted">@(isEdit ? "Update the party's information." : "Fill in the fields to register a new political party.")</small>
</div>

<div class="card border-0 shadow-sm" style="max-width: 540px;">
    <div class="card-body p-4">
        <form asp-action="@(isEdit ? "Edit" : "Create")" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            @if (isEdit)
            {
                <input asp-for="PoliticalPartyId" type="hidden" />
                <input asp-for="LogoUrl" type="hidden" />
            }

            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-medium">Party Name</label>
                <input asp-for="Name" class="form-control" placeholder="Enter party name" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Acronym" class="form-label fw-medium">Acronym</label>
                <input asp-for="Acronym" class="form-control" placeholder="e.g. PLD, PRD..." maxlength="10" />
                <span asp-validation-for="Acronym" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label fw-medium">
                    Description <span class="text-muted fw-normal">(optional)</span>
                </label>
                <textarea asp-for="Description" class="form-control" rows="3"
                          placeholder="Brief description of the party..."></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="LogoImg" class="form-label fw-medium">
                    Party Logo @(isEdit ? " — leave empty to keep current" : "")
                </label>

                @* Show current logo in edit mode *@
                @if (isEdit && !string.IsNullOrEmpty(ViewBag.CurrentLogo as string))
                {
                    <div class="mb-2">
                        <img src="@ViewBag.CurrentLogo" alt="Current logo"
                             style="width: 64px; height: 64px; object-fit: contain; border-radius: 50%; border: 2px solid #dee2e6; padding: 6px; background: #f8f9fa;" />
                        <small class="text-muted ms-2">Current logo</small>
                    </div>
                }

                <input asp-for="LogoImg" class="form-control" type="file" accept="image/*" />
                <span asp-validation-for="LogoImg" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
                <button type="submit" class="btn btn-dark">
                    @(isEdit ? "Save Changes" : "Create Party")
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}