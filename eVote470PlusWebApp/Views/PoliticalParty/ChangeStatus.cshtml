@model PoliticalPartyViewModel
@{
    ViewData["Title"] = Model.IsActive ? "Deactivate Party" : "Activate Party";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-center mt-5">
    <div class="card border-0 shadow-sm" style="max-width: 480px; width: 100%;">
        <div class="card-body p-4 text-center">

            <!-- Logo -->
            <div class="mb-3">
                @if (!string.IsNullOrEmpty(Model.LogoUrl))
                {
                    <img src="@Model.LogoUrl" alt="@Model.Name logo"
                         style="width: 72px; height: 72px; object-fit: contain; border-radius: 50%; border: 2px solid #dee2e6; padding: 6px; background: #f8f9fa;" />
                }
                else
                {
                    <span class="material-symbols-outlined @(Model.IsActive ? "text-danger" : "text-success")"
                          style="font-size: 48px;">
                        @(Model.IsActive ? "remove_circle" : "check_circle")
                    </span>
                }
            </div>

            <h5 class="fw-semibold mb-1">@Model.Name <span class="badge bg-dark">@Model.Acronym</span></h5>
            <p class="text-muted mb-4">
                @(Model.IsActive
                                ? "Are you sure you want to deactivate this political party? All candidates registered under this party will also be deactivated."
                                : "Are you sure you want to activate this political party?")
            </p>

            <div class="d-flex justify-content-center gap-2">
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                <form asp-action="ChangeStatus" asp-route-id="@Model.PoliticalPartyId" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="currentStatus" value="@Model.IsActive" />
                    <button type="submit" class="btn @(Model.IsActive ? "btn-danger" : "btn-success")">
                        @(Model.IsActive ? "Yes, deactivate" : "Yes, activate")
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>