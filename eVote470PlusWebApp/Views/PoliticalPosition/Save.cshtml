@model SavePoliticalPositionViewModel
@{
    bool isEdit = ViewBag.IsEdit == true;
    ViewData["Title"] = isEdit ? "Edit Political Position" : "New Political Position";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="mb-4">
    <h4 class="fw-semibold mb-0">@ViewData["Title"]</h4>
    <small class="text-muted">@(isEdit ? "Modify the political position details." : "Complete the fields to create a new position.")</small>
</div>

<div class="card border-0 shadow-sm" style="max-width: 540px;">
    <div class="card-body p-4">
        <form asp-action="@(isEdit ? "Edit" : "Create")" method="post">
            @Html.AntiForgeryToken()

            @if (isEdit)
            {
                <input asp-for="PoliticalPositionId" type="hidden" />
            }

            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-medium">Position Name</label>
                <input asp-for="Name" class="form-control" placeholder="Ex. Deputy, Senator, Mayor..." />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Description" class="form-label fw-medium">Description</label>
                <textarea asp-for="Description" class="form-control" rows="3"
                          placeholder="Briefly describe this political position..."></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
                <button type="submit" class="btn btn-dark">
                    @(isEdit ? "Save Changes" : "Create Position")
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}