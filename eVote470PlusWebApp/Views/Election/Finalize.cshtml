@model ElectionViewModel
@{
    ViewData["Title"] = "Finalize Election";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-center mt-5">
    <div class="card border-0 shadow-sm" style="max-width: 480px; width: 100%;">
        <div class="card-body p-4 text-center">

            <div class="mb-3">
                <span class="material-symbols-outlined text-warning" style="font-size: 48px;">how_to_vote</span>
            </div>

            <h5 class="fw-semibold mb-2">Finalize this election?</h5>
            <p class="text-muted mb-1"><strong>@Model.Name</strong></p>
            <p class="text-muted mb-4">
                Are you sure you want to finalize this election?
                This action cannot be undone and voting will be closed immediately.
            </p>

            <div class="d-flex justify-content-center gap-2">
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                <form asp-action="Finalize" asp-route-id="@Model.ElectionId" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="confirm" value="true" />
                    <button type="submit" class="btn btn-danger">Yes, finalize</button>
                </form>
            </div>
        </div>
    </div>
</div>