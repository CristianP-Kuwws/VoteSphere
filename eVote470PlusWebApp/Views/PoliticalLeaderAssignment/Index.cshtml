@model List<PoliticalLeaderAssignmentViewModel>
@{
    ViewData["Title"] = "Political Leader Assignment";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0 fw-semibold">Political Leader Assignment</h4>
        <small class="text-muted">Manage relationships between leaders and political parties</small>
    </div>
    @if (!(bool)ViewBag.HasActiveElection)
    {
        <a asp-action="Create" class="btn btn-dark">+ New Assignment</a>
    }
</div>

@if ((bool)ViewBag.HasActiveElection)
{
    <div class="alert alert-warning">
        There is an active election. Assignments cannot be created or deleted.
    </div>
}

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Leader</th>
                        <th>Party</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="3" class="text-center text-muted py-4">
                                No assignments registered.
                            </td>
                        </tr>
                    }
                    @foreach (var assignment in Model)
                    {
                        <tr>
                            <td class="align-middle fw-medium">@assignment.UserName</td>
                            <td class="align-middle">
                                <span class="badge bg-dark">@assignment.PartyAcronym</span>
                            </td>
                            <td class="text-center align-middle">
                                @if (!(bool)ViewBag.HasActiveElection)
                                {
                                    <a asp-action="Delete" asp-route-id="@assignment.PoliticalLeaderId"
                                       class="btn btn-sm btn-outline-danger">Unlink</a>
                                }
                                else
                                {
                                    <span class="text-muted small">Not available</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>