<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VoteSphere Admin</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1" rel="stylesheet" />

    <style>
        body {
            background-color: #f8f9ff;
        }

        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            vertical-align: middle;
            font-size: 18px;
        }

        .navbar-brand {
            font-weight: 700;
            letter-spacing: -0.01em;
        }
    </style>
</head>
<body class="d-flex flex-column min-vh-100">

    <header>
        <nav class="navbar navbar-expand-md navbar-dark bg-dark border-bottom shadow-sm mb-3">
            <div class="container-fluid">

                <a class="navbar-brand" asp-controller="AdminHome" asp-action="Index">
                    VoteSphere
                    <span class="badge bg-secondary ms-1" style="font-size: 0.65rem;">Admin</span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#adminNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="adminNav">

                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="AdminHome" asp-action="Index">
                                <span class="material-symbols-outlined">home</span> Home
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="PoliticalPosition" asp-action="Index">
                                <span class="material-symbols-outlined">work</span> Electoral Positions
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Citizen" asp-action="Index">
                                <span class="material-symbols-outlined">people</span> Citizens
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="PoliticalParty" asp-action="Index">
                                <span class="material-symbols-outlined">flag</span> Political Parties
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="User" asp-action="Index">
                                <span class="material-symbols-outlined">manage_accounts</span> Users
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="PoliticalLeaderAssignment" asp-action="Index">
                                <span class="material-symbols-outlined">assignment_ind</span> Political Leaders
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Election" asp-action="Index">
                                <span class="material-symbols-outlined">how_to_vote</span> Elections
                            </a>
                        </li>
                    </ul>

                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link text-danger" asp-controller="Login" asp-action="Logout">
                                <span class="material-symbols-outlined">logout</span> Log out
                            </a>
                        </li>
                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid px-4 flex-grow-1">

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @Html.Raw(TempData["Error"])
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <main role="main" class="pb-4">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top bg-white py-3 text-center text-muted" style="font-size: 0.78rem;">
        &copy; @DateTime.Now.Year VoteSphere &mdash; Administration Panel
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>