<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VoteSphere</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/VoteSphere.styles.css" asp-append-version="true" />

    <!-- Material Symbols -->
    <link rel="stylesheet"
          href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" />

    <style>
        body {
            background-color: #f8f9ff;
        }

        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            vertical-align: middle;
        }

        .navbar-brand {
            font-weight: 700;
            letter-spacing: -0.01em;
        }
    </style>
</head>
<body class="d-flex flex-column min-vh-100">

    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom shadow-sm mb-3">
            <div class="container-fluid">

                <a class="navbar-brand" asp-controller="Voting" asp-action="Index">
                    VoteSphere
                </a>

                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-flex justify-content-between">

                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link text-dark"
                               asp-controller="Voting"
                               asp-action="Index">
                                <span class="material-symbols-outlined me-1">how_to_vote</span>
                                Voting
                            </a>
                        </li>
                    </ul>

                    <div class="d-flex align-items-center gap-2">
                        <a asp-controller="Login"
                           asp-action="Index"
                           class="btn btn-sm btn-outline-dark">
                            <span class="material-symbols-outlined me-1">login</span>
                            Institutional Access
                        </a>
                    </div>

                </div>
            </div>
        </nav>
    </header>

    <div class="container flex-grow-1">

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show mt-3" role="alert">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (ViewBag.PendingMessage != null)
        {
            <div class="alert alert-warning alert-dismissible fade show mt-3" role="alert">
                @ViewBag.PendingMessage
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <main role="main" class="pb-4">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top bg-white py-3 text-center text-muted mt-auto">
        <div class="container">
            &copy; @DateTime.Now.Year - VoteSphere
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>