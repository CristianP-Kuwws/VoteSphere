@{
    ViewData["Title"] = "Access Denied";
}

<div class="d-flex justify-content-center align-items-center" style="min-height: 60vh;">
    <div class="col-12 col-md-6 col-lg-4 text-center">
        <div class="card shadow-sm border-0">
            <div class="card-body p-5">

                <div class="mb-4">
                    <span style="font-size: 4rem;">🔒</span>
                </div>

                <h4 class="fw-bold text-danger mb-2">Access Denied</h4>
                <p class="text-muted mb-4">
                    You do not have permission to access this section.
                </p>

                @* Redirect to corresponding home based on role *@
                @if (User.IsInRole("Administrator"))
                {
                    <a asp-controller="Home" asp-action="Index" asp-route-area="Admin" class="btn btn-primary">
                        Return to Admin Home
                    </a>
                }
                else if (User.IsInRole("PoliticalLeader"))
                {
                    <a asp-controller="Home" asp-action="Index" asp-route-area="Leader" class="btn btn-primary">
                        Return to Leader Home
                    </a>
                }
                else
                {
                    <a asp-controller="Voting" asp-action="Index" class="btn btn-primary">
                        Return to Home
                    </a>
                }

            </div>
        </div>
    </div>
</div>