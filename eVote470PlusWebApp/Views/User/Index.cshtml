@model List<ApplicationUserViewModel>
@{
    ViewData["Title"] = "Users";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0 fw-semibold">Users</h4>
        <small class="text-muted">Manage system users</small>
    </div>
    @if (!(bool)ViewBag.HasActiveElection)
    {
        <a asp-action="Create" class="btn btn-dark">+ New User</a>
    }
</div>

@if ((bool)ViewBag.HasActiveElection)
{
    <div class="alert alert-warning">
        There is an active election. Users cannot be created, edited or have their status changed.
    </div>
}

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>Last Name</th>
                        <th>Email</th>
                        <th>Username</th>
                        <th>Role</th>
                        <th class="text-center">Status</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">No users registered.</td>
                        </tr>
                    }
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="align-middle">@user.Name</td>
                            <td class="align-middle">@user.LastName</td>
                            <td class="align-middle text-muted">@user.Email</td>
                            <td class="align-middle">@user.UserName</td>

                            <!-- ROLE (nueva columna correcta) -->
                            <td class="align-middle">
                                @if (user.Role == "Administrator")
                                {
                                    <span class="badge bg-primary">Administrator</span>
                                }
                                else if (user.Role == "PoliticalLeader")
                                {
                                    <span class="badge bg-secondary">Political Leader</span>
                                }
                                else
                                {
                                    <span class="text-muted small">@user.Role</span>
                                }
                            </td>

                            <!-- STATUS (corregido) -->
                            <td class="text-center align-middle">
                                @if (user.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>

                            <!-- ACTIONS -->
                            <td class="text-center align-middle">
                                @if (!(bool)ViewBag.HasActiveElection)
                                {
                                    <a asp-action="Edit" asp-route-id="@user.Id"
                                       class="btn btn-sm btn-outline-dark me-1">Edit</a>

                                    @* Hide deactivate button for the currently logged in user *@
                                    @if (user.UserName != User.Identity?.Name)
                                    {
                                        <a asp-action="ChangeStatus" asp-route-id="@user.Id"
                                           class="btn btn-sm @(user.IsActive ? "btn-outline-danger" : "btn-outline-success")">
                                            @(user.IsActive ? "Deactivate" : "Activate")
                                        </a>
                                    }
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>