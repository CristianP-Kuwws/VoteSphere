@model PoliticalAllianceViewModel
@{
    ViewData["Title"] = "Reject Alliance";
    Layout = "~/Views/Shared/_LeaderLayout.cshtml";
}

<div class="d-flex justify-content-center mt-5">
    <div class="card border-0 shadow-sm" style="max-width: 480px; width: 100%;">
        <div class="card-body p-4 text-center">
            <div class="mb-3">
                <span class="material-symbols-outlined text-danger" style="font-size: 48px;">cancel</span>
            </div>
            <h5 class="fw-semibold mb-2">Reject this alliance?</h5>
            <p class="text-muted mb-4">
                Are you sure you want to reject the alliance request from
                <strong>@Model.SenderPartyName</strong>?
            </p>
            <div class="d-flex justify-content-center gap-2">
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                <form asp-action="Reject" asp-route-id="@Model.PoliticalAllianceId" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="confirm" value="true" />
                    <button type="submit" class="btn btn-danger">Yes, reject</button>
                </form>
            </div>
        </div>
    </div>
</div>