@{
    ViewData["Title"] = "Political Alliances";
    Layout = "~/Views/Shared/_LeaderLayout.cshtml";

    var pendingReceived = ViewBag.PendingReceived as List<PoliticalAllianceViewModel>;
    var sentRequests = ViewBag.SentRequests as List<PoliticalAllianceViewModel>;
    var activeAlliances = ViewBag.ActiveAlliances as List<PoliticalAllianceViewModel>;
    bool hasActiveElection = (bool)ViewBag.HasActiveElection;
    int currentPartyId = (int)ViewBag.CurrentPartyId;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0 fw-semibold">Political Alliances</h4>
        <small class="text-muted">Manage your party's alliance requests and active alliances</small>
    </div>
</div>

@if (hasActiveElection)
{
    <div class="alert alert-warning mb-4">
        There is an active election. Alliance actions are disabled.
    </div>
}

<!-- Section 1: Pending Received Requests -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-white fw-semibold d-flex justify-content-between align-items-center">
        <span>Pending Requests Received</span>
        <span class="badge bg-warning text-dark">@(pendingReceived?.Count ?? 0)</span>
    </div>

    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Requesting Party</th>
                    <th>Request Date</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (pendingReceived == null || !pendingReceived.Any())
                {
                    <tr>
                        <td colspan="3" class="text-center text-muted py-3">No pending requests received.</td>
                    </tr>
                }
                @foreach (var request in pendingReceived ?? new List<PoliticalAllianceViewModel>())
                {
                    <tr>
                        <td class="align-middle fw-medium">@request.SenderPartyName</td>
                        <td class="align-middle text-muted">@request.RequestDate.ToString("MMM dd, yyyy")</td>
                        <td class="text-center align-middle">
                            @if (!hasActiveElection)
                            {
                                <a asp-action="Accept" asp-route-id="@request.PoliticalAllianceId"
                                   class="btn btn-sm btn-outline-success me-1">Accept</a>
                                <a asp-action="Reject" asp-route-id="@request.PoliticalAllianceId"
                                   class="btn btn-sm btn-outline-danger">Reject</a>
                            }
                            else
                            {
                                <span class="text-muted small">Not available</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Section 2: Sent Requests -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-white fw-semibold d-flex justify-content-between align-items-center">
        <span>Sent Requests</span>
        @if (!hasActiveElection)
        {
            <a asp-action="Create" class="btn btn-sm btn-primary">+ New Request</a>
        }
    </div>

    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Target Party</th>
                    <th>Request Date</th>
                    <th>Status</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (sentRequests == null || !sentRequests.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted py-3">No requests sent.</td>
                    </tr>
                }

                @foreach (var request in sentRequests ?? new List<PoliticalAllianceViewModel>())
                {
                    <tr>
                        <td class="align-middle fw-medium">@request.ReceiverPartyName</td>
                        <td class="align-middle text-muted">@request.RequestDate.ToString("MMM dd, yyyy")</td>
                        <td class="align-middle">
                            @switch (request.Status)
                            {
                                case AllianceStatus.Pending:
                                    <span class="badge bg-warning text-dark">Awaiting Response</span>
                                    break;
                                case AllianceStatus.Accepted:
                                    <span class="badge bg-success">Accepted</span>
                                    break;
                                case AllianceStatus.Rejected:
                                    <span class="badge bg-danger">Rejected</span>
                                    break;
                            }
                        </td>

                        <td class="text-center align-middle">
                            @if (!hasActiveElection && request.Status != AllianceStatus.Accepted)
                            {
                                <a asp-action="Delete" asp-route-id="@request.PoliticalAllianceId"
                                   class="btn btn-sm btn-outline-danger">Delete</a>
                            }
                            else if (request.Status == AllianceStatus.Accepted)
                            {
                                <span class="text-muted small">Managed below</span>
                            }
                            else
                            {
                                <span class="text-muted small">Not available</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Section 3: Active Alliances -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white fw-semibold d-flex justify-content-between align-items-center">
        <span>Active Alliances</span>
        <span class="badge bg-success">@(activeAlliances?.Count ?? 0)</span>
    </div>

    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Allied Party</th>
                    <th>Alliance Date</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (activeAlliances == null || !activeAlliances.Any())
                {
                    <tr>
                        <td colspan="3" class="text-center text-muted py-3">No active alliances.</td>
                    </tr>
                }

                @foreach (var alliance in activeAlliances ?? new List<PoliticalAllianceViewModel>())
                {
                    <tr>
                        <td class="align-middle fw-medium">
                            @(alliance.SenderPartyId == currentPartyId
                                                    ? alliance.ReceiverPartyName
                                                    : alliance.SenderPartyName)
                    </td>

                        <td class="align-middle text-muted">
                            @(alliance.ResponseDate?.ToString("MMM dd, yyyy") ?? "—")
                        </td>

                        <td class="text-center align-middle">
                        @if (!hasActiveElection)
                            {
                                <a asp-action="EndAlliance" asp-route-id="@alliance.PoliticalAllianceId"
                                   class="btn btn-sm btn-outline-danger">End Alliance</a>
                            }
                            else
                            {
                                <span class="text-muted small">Not available</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>