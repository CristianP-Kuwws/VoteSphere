@model PoliticalAllianceViewModel
@{
    ViewData["Title"] = "End Alliance";
    Layout = "~/Views/Shared/_LeaderLayout.cshtml";
}

<div class="d-flex justify-content-center mt-5">
    <div class="card border-0 shadow-sm" style="max-width: 480px; width: 100%;">
        <div class="card-body p-4 text-center">
            <div class="mb-3">
                <span class="material-symbols-outlined text-danger" style="font-size: 48px;">handshake</span>
            </div>
            <h5 class="fw-semibold mb-2">End this alliance?</h5>
            <p class="text-muted mb-4">
                Are you sure you want to end the alliance with
                <strong>@(Model.SenderPartyId == (int)ViewBag.CurrentPartyId ? Model.ReceiverPartyName : Model.SenderPartyName)</strong>?
            </p>
            <div class="alert alert-warning text-start small">
                <strong>Warning:</strong> Ending this alliance will also remove any candidates
                from the allied party that are currently assigned to your political positions.
                This action cannot be undone.
            </div>
            <div class="d-flex justify-content-center gap-2">
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                <form asp-action="EndAlliance" asp-route-id="@Model.PoliticalAllianceId" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="confirm" value="true" />
                    <button type="submit" class="btn btn-danger">Yes, end alliance</button>
                </form>
            </div>
        </div>
    </div>
</div>